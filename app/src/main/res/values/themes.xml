<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BudgetMate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/surface_white</item>
        <item name="colorSecondary">@color/teal_primary</item>
        <item name="colorSecondaryVariant">@color/teal_dark</item>
        <item name="colorOnSecondary">@color/navy_dark</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorError">@color/error_red</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <style name="Theme.BudgetMate.Splash" parent="Theme.BudgetMate">
        <item name="android:windowBackground">@color/navy_dark</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
    </style>

    <style name="Theme.BudgetMate.NoActionBar" parent="Theme.BudgetMate">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_primary</item>
        <item name="android:textColor">@color/navy_dark</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/teal_primary</item>
        <item name="android:textColor">@color/teal_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>